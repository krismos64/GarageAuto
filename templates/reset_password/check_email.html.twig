{% extends 'base.html.twig' %}

{% block title %}Email de réinitialisation envoyé{% endblock %}

{% block body %}
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <h1 class="h3 mb-3 font-weight-normal">Vérifiez votre boîte mail</h1>
            <p>
                Si un compte correspond à cette adresse email, un message contenant un lien
                de réinitialisation vient de vous être envoyé.
                Ce lien expire dans {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
            </p>
            <p>
                Vous ne recevez rien ? Vérifiez vos courriers indésirables ou
                <a href="{{ path('app_forgot_password_request') }}" class="text-primary">réessayez</a>.
            </p>
        </div>
    </div>
</div>
{% endblock %}
