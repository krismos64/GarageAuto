{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            {% for flash_error in app.flashes('reset_password_error') %}
                <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
            {% endfor %}

            <div class="text-center">
                <h1 class="h3 mb-3 font-weight-normal">Mot de passe oublié</h1>
                <p class="mb-4">
                    Indiquez votre adresse email, nous vous enverrons un lien pour
                    réinitialiser votre mot de passe.
                </p>
            </div>

            {{ form_start(requestForm) }}
                <label for="{{ requestForm.email.vars.id }}" class="sr-only">Email</label>
                {{ form_widget(requestForm.email, { attr: { class: 'form-control', placeholder: 'Email' } }) }}
                {{ form_errors(requestForm.email) }}

                <div class="text-center mt-3">
                    <button class="btn btn-lg btn-primary" type="submit">Envoyer le lien de réinitialisation</button>
                </div>
            {{ form_end(requestForm) }}

            <div class="text-center mt-3">
                <a href="{{ path('app_login') }}">Retour à la connexion</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
