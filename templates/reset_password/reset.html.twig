{% extends 'base.html.twig' %}

{% block title %}Réinitialiser le mot de passe{% endblock %}

{% block body %}
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="text-center">
                <h1 class="h3 mb-3 font-weight-normal">Réinitialiser le mot de passe</h1>
            </div>

            {{ form_start(resetForm) }}
                <label for="{{ resetForm.plainPassword.first.vars.id }}" class="sr-only">Nouveau mot de passe</label>
                {{ form_widget(resetForm.plainPassword.first, { attr: { class: 'form-control', placeholder: 'Nouveau mot de passe' } }) }}
                {{ form_errors(resetForm.plainPassword.first) }}

                <label for="{{ resetForm.plainPassword.second.vars.id }}" class="sr-only mt-2">Confirmez le mot de passe</label>
                {{ form_widget(resetForm.plainPassword.second, { attr: { class: 'form-control mt-2', placeholder: 'Confirmez le mot de passe' } }) }}
                {{ form_errors(resetForm.plainPassword.second) }}

                <div class="text-center mt-3">
                    <button class="btn btn-lg btn-primary" type="submit">Réinitialiser le mot de passe</button>
                </div>
            {{ form_end(resetForm) }}
        </div>
    </div>
</div>
{% endblock %}
